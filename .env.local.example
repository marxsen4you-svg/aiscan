# ─── Clerk Auth ───────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Stripe ───────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Webhook secret: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── Stripe Price IDs ─────────────────────────────────────────
# Create products at: https://dashboard.stripe.com → Products
# Pro plan monthly price ID
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_ME
# Agency plan monthly price ID
STRIPE_PRICE_AGENCY_MONTHLY=price_REPLACE_ME

# ─── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_ME.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# ─── Resend Email ─────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=noreply@aiscan.com

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
